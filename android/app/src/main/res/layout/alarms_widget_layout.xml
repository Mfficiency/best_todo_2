<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/alarms_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">
        <TextView
            android:id="@+id/alarms_widget_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Alarms"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="15sp" />
        <TextView
            android:id="@+id/alarms_widget_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:textColor="@android:color/white"
            android:textSize="20sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/alarms_widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No alarms yet. Tap + to add one."
        android:textColor="#BBBBBB"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Row 0 -->
    <LinearLayout
        android:id="@+id/alarm_row_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView
            android:id="@+id/alarm_time_0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07:00"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:minWidth="56dp" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="10dp">
            <TextView
                android:id="@+id/alarm_name_0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Alarm"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/alarm_sub_0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Once"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#AAAAAA"
                android:textSize="11sp" />
        </LinearLayout>
        <TextView
            android:id="@+id/alarm_toggle_0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ON"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/alarm_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView
            android:id="@+id/alarm_time_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07:00"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:minWidth="56dp" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="10dp">
            <TextView
                android:id="@+id/alarm_name_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/alarm_sub_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#AAAAAA"
                android:textSize="11sp" />
        </LinearLayout>
        <TextView
            android:id="@+id/alarm_toggle_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ON"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/alarm_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView
            android:id="@+id/alarm_time_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:minWidth="56dp" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="10dp">
            <TextView
                android:id="@+id/alarm_name_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/alarm_sub_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#AAAAAA"
                android:textSize="11sp" />
        </LinearLayout>
        <TextView
            android:id="@+id/alarm_toggle_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ON"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:id="@+id/alarm_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">
        <TextView
            android:id="@+id/alarm_time_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:minWidth="56dp" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="10dp">
            <TextView
                android:id="@+id/alarm_name_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@android:color/white"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/alarm_sub_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="#AAAAAA"
                android:textSize="11sp" />
        </LinearLayout>
        <TextView
            android:id="@+id/alarm_toggle_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ON"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/alarms_widget_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#888888"
        android:textSize="11sp"
        android:paddingTop="2dp"
        android:visibility="gone" />
</LinearLayout>
